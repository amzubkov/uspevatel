{
  "expo": {
    "name": "uspevatel-app",
    "slug": "uspevatel-app",
    "scheme": "uspevatel",
    "version": "8.36",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.uspevatel.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "versionCode": 57,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "allowBackup": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению нужен доступ к фото для прикрепления изображений",
          "cameraPermission": "Приложению нужен доступ к камере для съёмки фото"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Приложению нужен доступ к календарю для отображения расписания"
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Приложению нужен микрофон для голосового добавления задач",
          "speechRecognitionPermission": "Приложению нужно распознавание речи для голосового добавления задач",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ]
  }
}
