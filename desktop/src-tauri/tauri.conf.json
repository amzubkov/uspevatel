{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Успеватель",
  "version": "1.0.0",
  "identifier": "com.uspevatel.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Успеватель",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 https://script.google.com https://script.googleusercontent.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCONFIG/snapshot-assets",
          "$APPCONFIG/snapshot-assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
